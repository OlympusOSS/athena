{
	"name": "@olympus/athena",
	"version": "1.1.4",
	"private": true,
	"scripts": {
		"dev": "next dev --webpack",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"ci": "biome ci && tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"snapshot-coverage": "node scripts/check-snapshot-coverage.mjs",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"audit:cookies": "grep -rn 'cookies\\.set.*athena-session.*{' src/ --exclude=cookie-options.ts && { echo 'FAIL: Unguarded athena-session cookie writes found. Use buildSessionCookieOptions() or buildSessionClearOptions() from lib/cookie-options.ts'; exit 1; } || exit 0",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,jsonc,md,css}": "biome check --write --no-errors-on-unmatched"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/OlympusOSS/athena.git"
	},
	"dependencies": {
		"@olympusoss/canvas": "^2.2.0",
		"@olympusoss/sdk": "^1.2.0",
		"@ory/hydra-client": "^26.2.0",
		"@ory/kratos-client": "^26.2.0",
		"@rjsf/core": "6.4.1",
		"@rjsf/utils": "6.4.1",
		"@rjsf/validator-ajv8": "6.3.1",
		"@tailwindcss/postcss": "^4.1.18",
		"@tanstack/react-query": "^5.90.19",
		"@tanstack/react-query-devtools": "^5.91.2",
		"axios": "^1.13.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"jwt-decode": "^4.0.0",
		"libphonenumber-js": "^1.12.34",
		"next": "16.1.6",
		"postcss": "^8.5.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.71.1",
		"react-syntax-highlighter": "^16.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.1.18",
		"zod": "^3.25.0",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@playwright/test": "^1.57.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.0.9",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/coverage-v8": "^3.2.4",
		"husky": "^9.1.0",
		"jsdom": "^29.0.2",
		"lint-staged": "^16.0.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"overrides": {
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3"
	}
}
